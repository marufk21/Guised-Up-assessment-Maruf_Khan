{
  "name": "guised-up",
  "private": true,
  "scripts": {
    "build": "turbo run build --ui=tui",
    "dev": "turbo run dev --ui=tui",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:ai": "node scripts/dev-ai.mjs",
    "dev:mobile": "node scripts/dev-mobile.mjs",
    "lint": "turbo run lint --ui=tui",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types --ui=tui"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
